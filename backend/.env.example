# Example environment variables for KISANBODHI backend

# Server Configuration
PORT=3001
NODE_ENV=development

# Weather API Configuration
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# eNAM Market API
ENAM_API_KEY=your_enam_api_key
ENAM_API_URL=https://api.enam.gov.in

# Agricultural News API
NEWS_API_KEY=your_news_api_key
NEWS_UPDATE_INTERVAL=3600000  # 1 hour in milliseconds

# Database Configuration (for future enhancement)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kisanbodhi
DB_USER=postgres
DB_PASSWORD=your_password

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API Keys for Third-party Services
MAPBOX_API_KEY=your_mapbox_key_for_geolocation
SATELLITE_API_KEY=your_satellite_imagery_key

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/kisanbodhi.log

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Alert Configuration
ALERT_EMAIL_ENABLED=false
ALERT_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Features
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true

# Crisis Alert Configuration
CRISIS_ALERT_THRESHOLD=80  # Risk score threshold for crisis alerts
CROP_LOSS_ESTIMATE_MODEL=v2  # Model version for crop loss estimation
INCOME_RISK_MODEL=v2  # Model version for income risk
