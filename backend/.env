# KISANBODHI Backend Configuration
# Development/Demo Mode - Mock data will be used when real APIs fail

# Server Configuration
PORT=3001
NODE_ENV=development

# Weather API Configuration
# Leave empty to use mock weather data
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# eNAM Market API
# Leave empty to use mock market data
ENAM_API_KEY=
ENAM_API_URL=https://api.enam.gov.in

# Agricultural News API
# Leave empty to use mock news
NEWS_API_KEY=
NEWS_UPDATE_INTERVAL=3600000

# Database Configuration (optional - for future)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kisanbodhi
DB_USER=postgres
DB_PASSWORD=demo

# Redis Configuration (optional - for future caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API Keys for Third-party Services (optional)
MAPBOX_API_KEY=
SATELLITE_API_KEY=

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/kisanbodhi.log

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,*

# Features
ENABLE_ANALYTICS=true
ENABLE_CACHING=true

# Demo Mode - Always use mock data for stable demo experience
FORCE_MOCK_DATA=false
